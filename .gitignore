# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# temporary/analysis scripts
scripts/analyze_*.mjs
scripts/check_*.mjs
scripts/compare_*.mjs
scripts/debug_*.mjs
scripts/deep_*.mjs
scripts/find_*.mjs
scripts/inspect_*.mjs
scripts/migrate_*.mjs
scripts/resolve_*.mjs
scripts/search_*.mjs
scripts/temp_*.mjs
scripts/dump_*.mjs

# excel lock files
data/~$*.xlsx
